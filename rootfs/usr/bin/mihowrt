#!/bin/ash

check_required_file() {
	[ -r "$1" ] || {
		echo "Error: required file '$1' is missing or not readable" >&2
		exit 1
	}
}

check_required_file /lib/functions.sh
check_required_file /usr/lib/mihowrt/constants.sh
check_required_file /usr/lib/mihowrt/helpers.sh
check_required_file /usr/lib/mihowrt/dns-state.sh
check_required_file /usr/lib/mihowrt/lists.sh
check_required_file /usr/lib/mihowrt/dns.sh
check_required_file /usr/lib/mihowrt/nft.sh
check_required_file /usr/lib/mihowrt/runtime-snapshot.sh
check_required_file /usr/lib/mihowrt/policy.sh
check_required_file /usr/lib/mihowrt/runtime.sh

. /lib/functions.sh
. /usr/lib/mihowrt/constants.sh
. /usr/lib/mihowrt/helpers.sh
. /usr/lib/mihowrt/dns-state.sh
. /usr/lib/mihowrt/lists.sh
. /usr/lib/mihowrt/dns.sh
. /usr/lib/mihowrt/nft.sh
. /usr/lib/mihowrt/runtime-snapshot.sh
. /usr/lib/mihowrt/policy.sh
. /usr/lib/mihowrt/runtime.sh

runtime_lock_file() {
	printf '%s\n' "${RUNTIME_LOCK_FILE:-${PKG_STATE_DIR:-/var/run/mihowrt}/runtime.lock}"
}

runtime_lock_owner_stale() {
	local owner="$1"

	case "$owner" in
		''|*[!0-9]*)
			return 0
			;;
	esac

	kill -0 "$owner" 2>/dev/null && return 1
	return 0
}

runtime_lock_acquire() {
	local lock_file="" lock_dir="" owner="" waited=0
	local timeout="${RUNTIME_LOCK_TIMEOUT:-120}"

	case "$timeout" in
		''|*[!0-9]*)
			timeout=120
			;;
	esac

	lock_file="$(runtime_lock_file)"
	lock_dir="$(dirname "$lock_file")"
	if command -v ensure_dir >/dev/null 2>&1; then
		ensure_dir "$lock_dir" || return 1
	else
		mkdir -p "$lock_dir" || return 1
	fi

	while ! ln -s "$$" "$lock_file" 2>/dev/null; do
		owner="$(readlink "$lock_file" 2>/dev/null || true)"
		if runtime_lock_owner_stale "$owner"; then
			rm -f "$lock_file"
			continue
		fi

		if [ "$waited" -ge "$timeout" ]; then
			err "Runtime state is busy by process $owner"
			return 1
		fi

		sleep 1
		waited=$((waited + 1))
	done
}

runtime_lock_release() {
	local lock_file="" owner=""

	lock_file="$(runtime_lock_file)"
	owner="$(readlink "$lock_file" 2>/dev/null || true)"
	[ "$owner" = "$$" ] && rm -f "$lock_file"
}

with_runtime_lock() {
	local rc=0

	runtime_lock_acquire || return 1
	"$@"
	rc=$?
	runtime_lock_release
	return "$rc"
}

run_service() {
	local pid dns_port cleanup_done=0 stop_requested=0 rc=1 cleanup_rc=0
	local clash_config="${CLASH_CONFIG:-$CLASH_DIR/config.yaml}"

	log "MihoWRT runtime bootstrap starting"
	load_runtime_config || return 1
	log "Runtime config loaded"
	validate_runtime_config || return 1
	log "Runtime config validated"
	ensure_dir "$PKG_STATE_DIR"
	init_runtime_layout || return 1
	log "Runtime layout ready"

	cleanup_service() {
		if [ "$cleanup_done" -eq 0 ]; then
			with_runtime_lock cleanup_runtime_state || cleanup_rc=$?
			cleanup_done=1
		fi
		rm -f "$SERVICE_PID_FILE"
	}

	clear_service_traps() {
		trap - INT TERM HUP
	}

	request_service_stop() {
		stop_requested=1
		[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && kill "$pid" 2>/dev/null || true
	}

	trap 'request_service_stop' INT TERM HUP

	"$CLASH_BIN" -d "$CLASH_DIR" -f "$clash_config" &
	pid=$!
	echo "$pid" > "$SERVICE_PID_FILE"
	log "Mihomo process spawned"

	dns_port="$(dns_listen_port "$MIHOMO_DNS_LISTEN")"
	if ! wait_for_mihomo_ready "$dns_port" "$MIHOMO_TPROXY_PORT" "$pid"; then
		err "Mihomo failed to become ready on DNS port $dns_port and TPROXY port $MIHOMO_TPROXY_PORT"
		kill "$pid" 2>/dev/null || true
		wait "$pid" 2>/dev/null || true
		cleanup_service
		clear_service_traps
		[ "$cleanup_rc" -eq 0 ] || return "$cleanup_rc"
		return 1
	fi
	log "Mihomo listeners ready"

	if ! with_runtime_lock apply_runtime_state; then
		err "Failed to apply runtime policy after Mihomo became ready"
		kill "$pid" 2>/dev/null || true
		wait "$pid" 2>/dev/null || true
		cleanup_service
		clear_service_traps
		[ "$cleanup_rc" -eq 0 ] || return "$cleanup_rc"
		return 1
	fi
	log "Runtime policy applied"

	log "MihoWRT service ready"
	rc=0
	wait "$pid" 2>/dev/null || rc=$?
	cleanup_service
	clear_service_traps
	[ "$cleanup_rc" -eq 0 ] || return "$cleanup_rc"

	if [ "$stop_requested" -eq 1 ]; then
		log "MihoWRT service stopped"
		return 0
	fi

	case "$rc" in
		0) return 0 ;;
		''|*[!0-9]*) return 1 ;;
	esac

	return 1
}

	case "$1" in
	prepare|start)
		with_runtime_lock prepare_runtime_state
		;;
	cleanup|stop)
		with_runtime_lock cleanup_runtime_state
		;;
	recover)
		with_runtime_lock recover_runtime_state
		;;
	reload|reload-policy)
		with_runtime_lock reload_runtime_state
		;;
	update-policy-lists)
		with_runtime_lock update_runtime_policy_lists
		;;
	migrate-policy-lists)
		migrate_policy_list_files
		;;
	service-running)
		service_running_state
		;;
	service-ready)
		service_ready_runtime_state
		;;
	restart-validated-service)
		init_script="/etc/init.d/${PKG_NAME:-mihowrt}"
		[ -x "$init_script" ] || {
			echo "Error: init script '$init_script' is missing or not executable" >&2
			exit 1
		}
		if current_config_has_validated_stamp; then
			MIHOWRT_SKIP_CLASH_TEST=1 "$init_script" restart
		else
			"$init_script" restart
		fi
		;;
	validate)
		load_runtime_config && validate_runtime_config
		;;
	run-service)
		run_service
		;;
	init-layout)
		init_runtime_layout
		;;
	read-config)
		[ -n "${2:-}" ] && CLASH_CONFIG="$2"
		read_config_json
		;;
	apply-config)
		[ -n "${2:-}" ] || {
			echo "Usage: $0 apply-config <temp-config-path>" >&2
			exit 1
		}
		with_runtime_lock apply_config_file "$2"
		;;
	apply-config-contents)
		[ "${2+x}" = x ] || {
			echo "Usage: $0 apply-config-contents <config-contents>" >&2
			exit 1
		}
		with_runtime_lock apply_config_contents "$2"
		;;
	subscription-json)
		subscription_url_json
		;;
	set-subscription-url)
		[ "${2+x}" = x ] || {
			echo "Usage: $0 set-subscription-url <url>" >&2
			exit 1
		}
		set_subscription_url "$2"
		;;
	fetch-subscription)
		[ -n "${2:-}" ] || {
			echo "Usage: $0 fetch-subscription <url>" >&2
			exit 1
		}
		fetch_subscription_config "$2"
		;;
	status-json)
		status_json
		;;
	logs-json)
		logs_json "${2:-200}"
		;;
	status)
		status_runtime_state
		;;
	*)
		echo "Usage: $0 {prepare|cleanup|recover|reload|reload-policy|update-policy-lists|migrate-policy-lists|service-running|service-ready|restart-validated-service|validate|run-service|init-layout|read-config|apply-config|apply-config-contents|subscription-json|set-subscription-url|fetch-subscription|status-json|logs-json|status}" >&2
		exit 1
		;;
esac
